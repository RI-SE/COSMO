################################################################################
# Python / packaging
################################################################################
__pycache__/
*.py[cod]
*$py.class

build/
dist/
*.egg-info/
.eggs/

################################################################################
# Virtual environments / local env files
################################################################################
.venv/
venv/
.env
.env.*
.conda/

################################################################################
# Test / type-check / lint caches
################################################################################
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
coverage.xml
htmlcov/

################################################################################
# IDE / editor
################################################################################
.vscode/
.idea/
*.swp
*~

################################################################################
# OS junk
################################################################################
.DS_Store
Thumbs.db

################################################################################
# COSMO: generated outputs (never commit)
################################################################################
output/
**/output/

# Add any other common generated dirs here if they exist in your workflow
runs/
# artifacts/
# .cosmo_cache/

################################################################################
# COSMO: downloadable-on-demand data (do not commit)
################################################################################
data/
**/data/

# If you want to keep a placeholder README inside data/, use this instead:
# data/*
# !data/README.md

################################################################################
# Large/binary artifacts policy
################################################################################
# Default: ignore these large binaries everywhere...
*.mp4
*.parquet
*.tiff
*.tif

# ...and ignore MCAP everywhere EXCEPT in examples/
*.mcap
!examples/**/*.mcap

################################################################################
# Executables / tools
################################################################################
*.exe
# If you decide that tools should be tracked, uncomment:
# !tools/*.exe

################################################################################
# Logs
################################################################################
*.log
examples/saro_roundabout/2025-10-16_C1/sequence1/An_VIDa_2025-10-16T131742CEST_D.json
